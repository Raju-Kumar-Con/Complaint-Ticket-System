@{
    ViewData["Title"] = "Raise Complaint";
}
@model ComplaintTicketSystem.Models.ComplaintModel

<h2>Raise Complaint</h2>

<form asp-controller="Complaint" asp-action="Raise"
      method="post">

    <div class="mb-3">

        <label>Category</label>

        <select asp-for="CategoryId"
                asp-items="ViewBag.CategoryList"
                class="form-control">

            <option value="">
                Select Category
            </option>

        </select>

        <span asp-validation-for="CategoryId"
              class="text-danger"></span>

    </div>

    <div class="mb-3">

        <label>Subject</label>

        <input asp-for="Subject"
               class="form-control" />

        <span asp-validation-for="Subject"
              class="text-danger"></span>

    </div>

    <div class="mb-3">

        <label>Description</label>

        <textarea asp-for="Description"
                      class="form-control">
        </textarea>

            <span asp-validation-for="Description"
                  class="text-danger"></span>

        </div>
        <button class="btn btn-primary">

            Save

        </button>

    </form>

    @section Scripts
    {
        @{
            await Html.RenderPartialAsync("_ValidationScriptsPartial");
        }
    }