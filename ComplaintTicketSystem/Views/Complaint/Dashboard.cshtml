@model ComplaintTicketSystem.Models.DashboardModel

@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

@{
    ViewData["Title"] = "Dashboard";

    var userName = HttpContextAccessor.HttpContext?.Session.GetString("UserName");
    var role = HttpContextAccessor.HttpContext?.Session.GetString("Role");
    
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h2 class="mb-0">Welcome, @userName</h2>
        <small class="text-muted">Complaint Management Dashboard</small>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div class="card shadow-sm border-0">
            <div class="card-body py-2">

                <select id="chartFilter" class="form-select">
                    <option value="user">👤 User Wise</option>
                    <option value="category">📂 Category Wise</option>
                </select>

            </div>
        </div>

    </div>

</div>

<!-- INFO CARDS -->
<div class="row mb-4">
    @if (role == "Admin")
    {
        <div class="col-md-3">
            <div class="card bg-warning text-white">
                <div class="card-body">
                    <h6>Pending</h6>
                    <h3>@Model.OpenCount</h3>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card bg-info text-white">
                <div class="card-body">
                    <h6>Assigned</h6>
                    <h3>@Model.AssignedCount</h3>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card bg-success text-white">
                <div class="card-body">
                    <h6>Resolved Count</h6>
                    <h3>@Model.ResolvedCount</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-danger text-white">
                <div class="card-body">
                    <h6>Rejected Count</h6>
                    <h3>@Model.RejectedCount</h3>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="col-md-3">
            <div class="card bg-secondary text-white">
                <div class="card-body">
                    <h6>Total Count</h6>
                    <h3>@Model.TotalComplaints</h3>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card bg-warning text-white">
                <div class="card-body">
                    <h6>Open Count</h6>
                    <h3>@Model.OpenCount</h3>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card bg-success text-white">
                <div class="card-body">
                    <h6>Resolved Count</h6>
                    <h3>@Model.ResolvedCount</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-danger text-white">
                <div class="card-body">
                    <h6>Rejected Count</h6>
                    <h3>@Model.RejectedCount</h3>
                </div>
            </div>
        </div>
    }

</div>

<div id="myChart" style="height:500px;"></div>

@section Scripts
{
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
@* 
    <script src="https://cdn.jsdelivr.net/npm/ag-charts-community@latest/dist/umd/ag-charts-community.js"></script> *@
    <script src="https://cdn.jsdelivr.net/npm/ag-charts-community@9.3.0/dist/umd/ag-charts-community.js"></script>
    <script src="~/js/dashboard.js"></script>
}
