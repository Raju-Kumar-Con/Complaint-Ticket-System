@model ComplaintTicketSystem.Models.LoginModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Login</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

    <style>
        /* Background */
        body {
            margin: 0;
            height: 100vh;
            font-family: 'Segoe UI', sans-serif;
        background: linear-gradient(135deg,#0d6efd,#4facfe);
            overflow: hidden;
        }

        /* Center container */
        .login-wrapper {
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        /* Card animation */
        .login-card {
            width: 380px;
            background: #fff;
            border-radius: 15px;
            padding: 30px;
            box-shadow: 0 15px 40px rgba(0,0,0,0.3);

            /* animation */
            opacity: 0;
            transform: translateY(50px);
            animation: fadeSlideIn 0.8s ease forwards;
        }

        /* Keyframes */
        @@keyframes fadeSlideIn {
            from {
                opacity: 0;
                transform: translateY(60px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Form fields animation */
        .form-control {
            border-radius: 10px;
            transition: all 0.3s ease;
        }

        .form-control:focus {
            box-shadow: 0 0 10px rgba(0,123,255,0.3);
            transform: scale(1.02);
        }

        /* Button animation */
        .btn-login {
            background: linear-gradient(135deg, #00c6ff, #0072ff);
            border: none;
            border-radius: 10px;
            transition: all 0.3s ease;
        }

        .btn-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(0,114,255,0.3);
        }

        /* Title animation */
        .title {
            opacity: 0;
            transform: translateX(-30px);
            animation: slideLeft 0.8s ease forwards;
            animation-delay: 0.2s;
        }

        @@keyframes slideLeft {
            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        /* Inputs stagger effect */
        .field {
            opacity: 0;
            transform: translateY(20px);
            animation: fieldFade 0.6s ease forwards;
        }

        .field:nth-child(1) { animation-delay: 0.3s; }
        .field:nth-child(2) { animation-delay: 0.4s; }
        .field:nth-child(3) { animation-delay: 0.5s; }

        @@keyframes fieldFade {
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .link-text {
            font-size: 14px;
        }
    </style>
</head>

<body>

<div class="login-wrapper">

    <div class="login-card">

        <h3 class="text-center mb-4 title">Welcome Back</h3>

        <form asp-action="Login" method="post">

            <div class="mb-3 field">
                <label>Email</label>
                <input asp-for="Email" class="form-control" placeholder="Enter email" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="mb-3 field">
                <label>Password</label>
                <input asp-for="Password" type="password" class="form-control" placeholder="Enter password" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <button class="btn btn-login w-100 field">
                Login
            </button>

        </form>

        <div class="text-center mt-3 link-text field">
            Don't have an account?
            <a asp-action="Register">Sign up</a>
        </div>

    </div>

</div>

<partial name="_ValidationScriptsPartial" />

</body>
</html>

<script>
    localStorage.removeItem("chartFilter");
</script>