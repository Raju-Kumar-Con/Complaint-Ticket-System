@model ComplaintTicketSystem.Models.UserModel

@{
    ViewData["Title"] = "Edit User";

    var hobbies = (Model.Hobbies ?? "")
        .Split(',', StringSplitOptions.RemoveEmptyEntries)
        .Select(x => x.Trim())
        .ToList();
}

<style>

    .edit-container {
        height: calc(100vh - 250px);
        overflow-y: auto;
        overflow-x: hidden;
    }

        .edit-container .row {
            margin-left: 0;
            margin-right: 0;
        }

        .edit-container .col-md-6,
        .edit-container .col-md-12 {
            padding-left: 10px;
            padding-right: 10px;
        }

</style>


<div class="card shadow">

    <div class="card-header bg-warning">
        <h5 class="mb-0">
            <i class="bi bi-pencil-square"></i>
            Edit User
        </h5>
    </div>


    <div class="card-body edit-container">


        <form asp-action="EditUser"
              method="post"
              enctype="multipart/form-data">


            <input type="hidden" asp-for="UserId" />

            <input type="hidden" asp-for="ProfileImage" />


            <div asp-validation-summary="ModelOnly"
                 class="text-danger mb-3">
            </div>



            <div class="row">


                <!-- Name -->
                <div class="col-md-6 mb-3">

                    <label asp-for="UserName"
                           class="form-label">
                        Name
                    </label>

                    <input asp-for="UserName"
                           class="form-control"
                           placeholder="Enter Name" />

                    <span asp-validation-for="UserName"
                          class="text-danger"></span>

                </div>



                <!-- Email -->
                <div class="col-md-6 mb-3">

                    <label asp-for="Email"
                           class="form-label">
                        Email
                    </label>

                    <input asp-for="Email"
                           class="form-control"
                           readonly />

                    <span asp-validation-for="Email"
                          class="text-danger"></span>

                </div>



                <!-- Mobile -->
                <div class="col-md-6 mb-3">

                    <label asp-for="MobileNo"
                           class="form-label">
                        Mobile Number
                    </label>

                    <input asp-for="MobileNo"
                           class="form-control"
                           placeholder="Enter Mobile Number" />

                    <span asp-validation-for="MobileNo"
                          class="text-danger"></span>

                </div>



                <!-- DOB -->
                <div class="col-md-6 mb-3">

                    <label asp-for="DOB"
                           class="form-label">
                        Date of Birth
                    </label>

                    <input asp-for="DOB"
                           type="date"
                           class="form-control" />

                    <span asp-validation-for="DOB"
                          class="text-danger"></span>

                </div>



                <!-- Gender -->
                <div class="col-md-6 mb-3">

                    <label class="form-label">
                        Gender
                    </label>


                    <div class="mt-2">

                        <div class="form-check form-check-inline">

                            <input class="form-check-input"
                                   asp-for="Gender"
                                   type="radio"
                                   value="Male" />

                            <label class="form-check-label">
                                Male
                            </label>

                        </div>


                        <div class="form-check form-check-inline">

                            <input class="form-check-input"
                                   asp-for="Gender"
                                   type="radio"
                                   value="Female" />

                            <label class="form-check-label">
                                Female
                            </label>

                        </div>

                    </div>


                    <span asp-validation-for="Gender"
                          class="text-danger"></span>

                </div>




                <!-- Marital Status -->
                <div class="col-md-6 mb-3">


                    <label asp-for="MaritalStatus"
                           class="form-label">
                        Marital Status
                    </label>


                    <select asp-for="MaritalStatus"
                            class="form-control">

                        <option value="">
                            -- Select Status --
                        </option>

                        <option value="Single">
                            Single
                        </option>

                        <option value="Married">
                            Married
                        </option>

                    </select>


                    <span asp-validation-for="MaritalStatus"
                          class="text-danger"></span>


                </div>




                <!-- Hobbies -->
                <div class="col-md-12 mb-3">


                    <label class="form-label">
                        Hobbies
                    </label>


                    <div class="border rounded p-2">


                        @foreach (var hobby in new[] { "Reading", "Music", "Sports" })
                        {

                            <div class="form-check form-check-inline">


                                <input class="form-check-input"
                                       type="checkbox"
                                       name="SelectedHobbies"
                                       value="@hobby"
                                @(hobbies.Contains(hobby) ? "checked" : "") />


                                <label class="form-check-label">
                                    @hobby
                                </label>


                            </div>

                        }


                    </div>


                    <span class="text-danger">
                        @Html.ValidationMessage("Hobbies")
                    </span>


                </div>




                <!-- Address -->
                <div class="col-md-12 mb-3">


                    <label asp-for="Address"
                           class="form-label">
                        Address
                    </label>


                    <textarea asp-for="Address"
                              rows="3"
                              class="form-control"
                              placeholder="Enter Address"></textarea>


                    <span asp-validation-for="Address"
                          class="text-danger"></span>


                </div>





                <!-- Current Image -->
                <div class="col-md-6 mb-3">


                    <label class="form-label">
                        Current Profile Image
                    </label>


                    <div class="profile-preview mt-2">


                        @if (!string.IsNullOrEmpty(Model.ProfileImage))
                        {

                            <img src="~/uploads/profile/@Model.ProfileImage"
                                 width="130"
                                 height="130"
                                 class="rounded border" />

                        }
                        else
                        {
                            <span>No Image</span>
                        }


                    </div>


                </div>





                <!-- New Image -->
                <div class="col-md-6 mb-3">


                    <label asp-for="ImageFile"
                           class="form-label">
                        Change Profile Image
                    </label>


                    <input asp-for="ImageFile"
                           type="file"
                           class="form-control"
                           accept=".jpg,.jpeg,.png" />


                    <small class="text-muted">
                        Only JPG, JPEG and PNG allowed
                    </small>


                    <span asp-validation-for="ImageFile"
                          class="text-danger d-block"></span>


                </div>



            </div>




            <div class="mt-3">


                <button type="submit"
                        class="btn btn-primary">

                    <i class="bi bi-save"></i>
                    Update User

                </button>



                <a asp-action="Users"
                   class="btn btn-secondary">

                    <i class="bi bi-arrow-left"></i>
                    Back

                </a>


            </div>


        </form>


    </div>

</div>



@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}